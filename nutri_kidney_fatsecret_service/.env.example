# FatSecret API Credentials
FATSECRET_CONSUMER_KEY=your_fatsecret_consumer_key
FATSECRET_CONSUMER_SECRET=your_fatsecret_consumer_secret
# OAuth2 credentials from the FatSecret application dashboard.
# Omit these when they are the same as the consumer key and secret above.
FATSECRET_CLIENT_ID=your_fatsecret_oauth2_client_id
FATSECRET_CLIENT_SECRET=your_fatsecret_oauth2_client_secret
FATSECRET_IMAGE_RECOGNITION_SCOPE=image-recognition

# USDA FoodData Central API Key
USDA_FDC_API_KEY=your_usda_fdc_api_key

# API Configuration
FATSECRET_API_BASE_URL=https://platform.fatsecret.com/rest/server.api
FATSECRET_IMAGE_UPLOAD_URL=https://platform.fatsecret.com/rest/image-recognition/v2
FATSECRET_OAUTH2_TOKEN_URL=https://oauth.fatsecret.com/connect/token

# Service Configuration
REQUEST_TIMEOUT=10
FATSECRET_IMAGE_TIMEOUT=45
FATSECRET_IMAGE_RETRIES=1
MAX_IMAGE_SIZE_MB=5 
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg
ENVIRONMENT=development
DEBUG=True
